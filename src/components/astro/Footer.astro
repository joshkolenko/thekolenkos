---
import Hills from "@/svg/hills.svg";
import clsx from "clsx";

const { hasSlot } = Astro.props;
---

<div class="relative bg-primary">
  <div class="bg-base-200 relative w-full h-24 lg:h-[7.5vw] overflow-hidden -my-[1px]">
    <Hills
      class="min-w-5xl w-full absolute lg:relative left-1/2 lg:left-0 -translate-x-1/2 lg:translate-0 fill-primary top-[1px]"
    />
  </div>
  <div class={clsx(hasSlot && "pt-12 px-12 pb-24 flex flex-col")}>
    <slot />
  </div>
  <div class="relative bg-transparent w-full h-24 lg:h-[7.5vw] overflow-hidden -my-[1px]">
    <Hills
      class="min-w-5xl w-[150vw] reflex absolute lg:relative lg:left-0 lg:translate-0 fill-neutral -bottom-[1px]"
    />
  </div>
</div>
