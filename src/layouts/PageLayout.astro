---
import Footer from "@/components/astro/Footer.astro";
import Header from "@/components/astro/Header.astro";
import Nav from "@/components/astro/Nav.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import clsx from "clsx";

const { title, description, defaultWrapperClasses = true, wrapperClass } = Astro.props;

const hasHeaderSlot = Astro.slots.has("header");
const hasFooterSlot = Astro.slots.has("footer");
---

<BaseLayout title={title} description={description}>
  <Nav />
  <Header hasSlot={hasHeaderSlot}>
    <slot name="header" />
  </Header>
  <main class="bg-base-200 relative">
    <div
      class={clsx(
        defaultWrapperClasses && "px-8 pt-12 pb-28 md:pb-32 lg:pb-40 md:max-w-5xl mx-auto",
        wrapperClass
      )}
    >
      <slot />
    </div>
  </main>
  <Footer hasSlot={hasFooterSlot}>
    <slot name="footer" />
  </Footer>
</BaseLayout>
