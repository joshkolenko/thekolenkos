---
import PageLayout from "@/layouts/PageLayout.astro";
import ResponseDashboard from "@/components/react/ResponseDashboard";
import { actions } from "astro:actions";

export const prerender = false;

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const id = Number(formData.get("id"));

  if (!Number.isNaN(id)) {
    await Astro.callAction(actions.deleteRsvp, { id });
  }

  return Astro.redirect(Astro.url.pathname);
}

const { data: rsvpsData, error: rsvpsError } = await Astro.callAction(actions.getRsvps, null);
const { data: numInvitedData, error: numInvitedError } = await Astro.callAction(
  actions.getSetting,
  {
    key: "numInvited",
  }
);

const rsvps = rsvpsError ? [] : rsvpsData.value || [];
const numInvited = numInvitedError ? 0 : Number(numInvitedData.value);
---

<PageLayout title="Admin" description="Admin dashboard">
  <ResponseDashboard rsvps={rsvps} numInvited={numInvited} client:load />
</PageLayout>
