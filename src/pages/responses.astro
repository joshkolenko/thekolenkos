---
import PageLayout from "@/layouts/PageLayout.astro";
import ResponsesTable from "@/components/react/ResponsesTable";
import { actions } from "astro:actions";

export const prerender = false;

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const id = Number(formData.get("id"));

  if (!Number.isNaN(id)) {
    await Astro.callAction(actions.deleteRsvp, { id });
  }

  return Astro.redirect(Astro.url.pathname);
}

const { data } = await Astro.callAction(actions.getRsvps, null);
const rsvps = data?.rsvps ?? [];
---

<PageLayout title="Admin" description="Admin dashboard" wrapperClass="max-w-[1920px]!">
  <h1 slot="header" class="text-center text-base-200 text-5xl md:text-6xl">Responses</h1>
  <ResponsesTable rsvps={rsvps} client:load />
</PageLayout>
