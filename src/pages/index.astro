---
import PageLayout from "@/layouts/PageLayout.astro";

import { EngagementCarousel } from "@/components/react/EngagementCarousel";

import Champagne from "@/svg/champagne.svg";
import Heart10 from "@/svg/hearts/heart-10.svg";
---

<PageLayout
  title="The Kolenkos"
  description="Taylor and Josh's wedding"
  defaultWrapperClasses={false}
  wrapperClass="pb-32 md:pb-40"
>
  <Fragment slot="header">
    <h1 class="visually-hidden">The Kolenkos</h1>
    <p
      class="font-serif text-center text-base-200 text-[clamp(1.75rem,3.5vw,3.5rem)] leading-[1.3em] tracking-tight max-w-[44ch] mx-auto mt-12"
    >
      You're invited to celebrate the wedding of <span class="lg:block">
        Taylor Diaz & Joshua Kolenko on September 17, 2026
      </span> at <a
        href="https://g.co/kgs/DBe6S4a"
        target="_blank"
        rel="noopener noreferrer"
        class="underline underline-offset-6 decoration-3">Lakeside Gardens in Portland, Oregon.</a
      >
    </p>
  </Fragment>
  <div class="bg-base-200 relative z-10 text-center">
    <div class="w-80 mx-auto mb-4">
      <Champagne class="block fill-primary" />
    </div>
    <div class="px-8 prose-lg md:prose-xl">
      <h2>We're getting married!</h2>
      <p>After 9 wonderful years together, we're finally tying the knot!</p>
      <div class="divider max-w-1/2 md:max-w-100 mx-auto my-12 md:my-18"></div>
      <h2>The Engagement</h2>
      <p>We got engaged on December 28, 2024 as a family Christmas finale.</p>
    </div>
    <div class="mx-auto mt-18">
      <EngagementCarousel client:load />
    </div>
    <div
      class="grid gap-16 md:gap-6 grid-cols-1 md:grid-cols-[1fr_auto_1fr] items-center justify-items-center mt-32 md:mt-42 max-w-[1600px] mx-auto whitespace-nowrap"
    >
      <div class="flex flex-col gap-8">
        <h3 class="font-sans wght-850 tracking-widest text-xl uppercase text-base-content/50 mt-0">
          When
        </h3>
        <p
          class="font-serif text-4xl lg:text-5xl text-base-content leading-13 lg:leading-16 -tracking-[0.0125em] mb-0"
        >
          Thursday <br /> September 17, 2026 <br /> 5:30pm
        </p>
      </div>
      <div class="relative w-10 md:top-8 overflow-visible">
        <Heart10 />
      </div>
      <div class="flex flex-col gap-8">
        <h3 class="font-sans wght-850 tracking-widest text-xl uppercase text-base-content/50 mt-0">
          Where
        </h3>
        <p
          class="font-serif text-4xl lg:text-5xl text-base-content leading-13 lg:leading-16 -tracking-[0.0125em] mb-0"
        >
          Lakeside Gardens <br /> 16211 SE Foster Rd <br /> Portland, OR 97236
        </p>
      </div>
    </div>
  </div>
  <Fragment slot="footer">
    <h2 class="font-serif text-center text-4xl md:text-5xl text-balance mb-10">
      We'd love if you could join us.
    </h2>
    <a class="btn btn-neutral btn-lg w-full md:max-w-80 mx-auto" href="/rsvp">RSVP</a>
  </Fragment>
</PageLayout>
